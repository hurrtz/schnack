{
  "expo": {
    "name": "VoxAI",
    "slug": "voxai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tobiaswinkler.voxai",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VoxAI needs microphone access to record your voice for conversations."
      },
      "appleTeamId": "X7H939KJR7"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-audio",
      "./plugins/withBuildReactNativeFromSource"
    ],
    "scheme": "voxai",
    "icon": "./assets/branding/appIcon.png",
    "android": {
      "package": "com.tobiaswinkler.voxai"
    }
  }
}
